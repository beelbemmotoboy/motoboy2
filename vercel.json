{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/obras",
      "destination": "/obras/index.html"
    },
    {
      "source": "/obras/(.*)",
      "destination": "/obras/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
